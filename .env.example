# Public Supabase project settings (safe for browser use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never expose this value with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated KMI staff emails allowed to enter /admin.
KMI_STAFF_EMAILS=

# Optional local-only editor bypass. Never enable in Vercel.
KMI_LOCAL_EDITOR=false

# Verified giving methods. Configure at least one before promoting production.
# Keep bank and GCash details server-only; they are rendered by the Give page.
KMI_CARD_GIVING_URL=
KMI_BANK_GIVING_DETAILS=
KMI_GCASH_GIVING_DETAILS=
KMI_SITE_URL=https://www.kapatidministry.org

# Used by the production verification script. Defaults to the public domain.
KMI_PRODUCTION_URL=https://www.kapatidministry.org
