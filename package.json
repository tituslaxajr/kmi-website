{
  "name": "kapatid-ministry",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next",
    "test": "npm run build && node --test tests/*.test.mjs",
    "env:check": "node --env-file-if-exists=.env.local scripts/check-env.mjs",
    "supabase:verify": "node --env-file=.env.local scripts/verify-supabase.mjs",
    "production:verify": "node --env-file=.env.local scripts/verify-production.mjs",
    "launch:verify": "npm run env:check && npm run supabase:verify && npm run production:verify"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/newsreader": "^5.2.8",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "next": "16.2.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "type": "module"
}
